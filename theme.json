{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"blocks": {
			"core/button": {
				"spacing": {
					"spacingSizes": [
						{ "name": "xSmall", "size": "10px", "slug": "x-small" },
						{ "name": "Small", "size": "15px", "slug": "small" },
						{ "name": "Medium", "size": "20px", "slug": "medium" },
						{ "name": "Large", "size": "30px", "slug": "large" },
						{ "name": "xLarge", "size": "40px", "slug": "x-large" }
					]
				}
			}
		},
		"border": {
			"radiusSizes": [
				{ "name": "Small", "size": "4px", "slug": "small" },
				{ "name": "Medium", "size": "8px", "slug": "medium" },
				{ "name": "Large", "size": "12px", "slug": "large" },
				{ "name": "xLarge", "size": "20px", "slug": "x-large" }
			]
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"duotone": [
				{ "colors": [ "#000000", "#ffffff" ], "name": "Black / White", "slug": "black-white" },
				{ "colors": [ "#dd0099", "#ffffff" ], "name": "Accent / White", "slug": "accent-white" }
			],
			"gradients": [
				{
					"gradient": "linear-gradient(to top, var(--wp--preset--color--black) 0%, var(--wp--preset--color--black-50) 100%)",
					"name": "Fade Up",
					"slug": "fade-up"
				},
				{
					"gradient": "linear-gradient(to bottom, var(--wp--preset--color--black) 0%, var(--wp--preset--color--black-50) 100%)",
					"name": "Fade Down",
					"slug": "fade-down"
				},
				{
					"gradient": "linear-gradient(to left, var(--wp--preset--color--black) 0%, var(--wp--preset--color--black-50) 100%)",
					"name": "Fade Left",
					"slug": "fade-left"
				},
				{
					"gradient": "linear-gradient(to right, var(--wp--preset--color--black) 0%, var(--wp--preset--color--black-50) 100%)",
					"name": "Fade Right",
					"slug": "fade-right"
				}
			],
			"palette": [
				{ "color": "#000000", "name": "Black", "slug": "black" },
				{ "color": "#000000cc", "name": "Black 80", "slug": "black-80" },
				{ "color": "#00000099", "name": "Black 60", "slug": "black-60" },
				{ "color": "#00000080", "name": "Black 50", "slug": "black-50" },
				{ "color": "#00000033", "name": "Black 20", "slug": "black-20" },
				{ "color": "#0000001a", "name": "Black 10", "slug": "black-10" },
				{ "color": "#ffffff", "name": "White", "slug": "white" },
				{ "color": "#ffffffcc", "name": "White 80", "slug": "white-80" },
				{ "color": "#ffffff99", "name": "White 60", "slug": "white-60" },
				{ "color": "#ffffff80", "name": "White 50", "slug": "white-50" },
				{ "color": "#ffffff33", "name": "White 20", "slug": "white-20" },
				{ "color": "#ffffff1a", "name": "White 10", "slug": "white-10" },
				{ "color": "#dd0099", "name": "Accent", "slug": "accent" },
				{ "color": "#dd0099cc", "name": "Accent 80", "slug": "accent-80" },
				{ "color": "#dd009999", "name": "Accent 60", "slug": "accent-60" },
				{ "color": "#dd009980", "name": "Accent 50", "slug": "accent-50" },
				{ "color": "#dd009933", "name": "Accent 20", "slug": "accent-20" },
				{ "color": "#dd00991a", "name": "Accent 10", "slug": "accent-10" }
			]
		},
		"custom": {
			"lineHeight": { "x-small": 1.1, "small": 1.25, "medium": 1.5, "large": 1.75, "x-large": 2 }
		},
		"layout": { "contentSize": "640px", "wideSize": "1280px" },
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{ "name": "Light", "shadow": "0 0 5px rgba(0, 0, 0, 0.1)", "slug": "light" },
				{ "name": "Offset", "shadow": "10px 10px 0 var(--wp--preset--color--accent)", "slug": "solid" }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "name": "20", "size": "clamp(15px, 2vw, 20px)", "slug": "20" },
				{ "name": "30", "size": "clamp(25px, 3vw, 30px)", "slug": "30" },
				{ "name": "40", "size": "clamp(30px, 4vw, 40px)", "slug": "40" },
				{ "name": "60", "size": "clamp(40px, 6vw, 60px)", "slug": "60" },
				{ "name": "80", "size": "clamp(60px, 8vw, 80px)", "slug": "80" },
				{ "name": "100", "size": "clamp(70px, 10vw, 100px)", "slug": "100" },
				{ "name": "120", "size": "clamp(80px, 12vw, 120px)", "slug": "120" }
			],
			"units": [ "%", "px", "em", "rem", "vh", "vw" ]
		},
		"typography": {
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": { "maxViewportWidth": "1280px", "minViewportWidth": "640px" },
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontDisplay": "block",
							"fontFamily": "Outfit",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/outfit/outfit.woff2"
							]
						},
						{
							"fontDisplay": "block",
							"fontFamily": "Outfit",
							"fontStyle": "italic",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/outfit/outfit.woff2"
							]
						}
					],
					"fontFamily": "Outfit, sans-serif",
					"name": "Outfit",
					"slug": "outfit"
				}
			],
			"fontSizes": [
				{ "fluid": false, "name": "xxSmall", "size": "12px", "slug": "xx-small" },
				{ "fluid": false, "name": "xSmall", "size": "14px", "slug": "x-small" },
				{ "fluid": false, "name": "Small", "size": "16px", "slug": "small" },
				{ "fluid": false, "name": "Medium", "size": "18px", "slug": "medium" },
				{ "fluid": false, "name": "Base", "size": "20px", "slug": "base" },
				{
					"fluid": {
						"min": "20px",
						"max": "24px"
					},
					"name": "Large",
					"size": "24px",
					"slug": "large"
				},
				{
					"fluid": {
						"min": "30px",
						"max": "36px"
					},
					"name": "xLarge",
					"size": "36px",
					"slug": "x-large"
				},
				{
					"fluid": {
						"min": "36px",
						"max": "48px"
					},
					"name": "xxLarge",
					"size": "48px",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"min": "48px",
						"max": "72px"
					},
					"name": "xxxLarge",
					"size": "72px",
					"slug": "xxx-large"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"variations": {
					"fill-alt": {
						"color": {
							"text": "var(--wp--preset--color--white)"
						},
						":hover": {
							"color": {
								"background": "transparent"
							}
						}
					},
					"outline": {
						"border": {
							"color": "var(--wp--preset--color--accent)",
							"style": "solid",
							"width": "1px"
						},
						"spacing": {
							"padding": {
								"top": "20px",
								"right": "30px",
								"bottom": "20px",
								"left": "30px"
							}
						},
						":hover": {
							"color": {
								"background": "var(--wp--preset--color--accent)",
								"text": "var(--wp--preset--color--white)"
							}
						}
					},
					"outline-alt": {
						"color": {
							"background": "transparent",
							"text": "var(--wp--preset--color--white)"
						},
						":hover": {
							"color": {
								"background": "var(--wp--preset--color--accent)"
							}
						}
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--20)"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--black)",
					"text": "var(--wp--preset--color--white)"
				},
				"css": "& code { overflow-x: scroll; tab-size: 4; white-space: pre !important; }",
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--40)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)"
				}
			},
			"core/cover": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/heading": {
				"variations": {
					"balanced": {
						"css": "&.is-style-balanced { text-wrap: balance; }"
					},
					"eyebrow": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--x-small)",
							"fontWeight": "500",
							"letterSpacing": "0.05em",
							"lineHeight": "var(--wp--custom--line-height--medium)",
							"textTransform": "uppercase"
						}
					}
				}
			},
			"core/image": {
				"variations": {
					"zoom": {
						"css": "&.is-style-zoom { overflow: hidden; } &.is-style-zoom img { transition: transform var(--powder-motion-slow) var(--powder-motion-ease); } &.is-style-zoom:hover img { transform: scale(var(--powder-motion-scale)); }"
					}
				}
			},
			"core/list": {
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--20)"
					}
				},
				"variations": {
					"no-style": {
						"css": "&.is-style-no-style { list-style-type: none; padding-left: 0; }"
					}
				}
			},
			"core/navigation": {
				"css": "& .wp-block-navigation-item:hover { color: var(--wp--preset--color--accent); }",
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--20)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "var(--wp--custom--line-height--medium)"
				}
			},
			"core/navigation-submenu": {
				"border": {
					"color": "currentColor !important"
				}
			},
			"core/paragraph": {
				"variations": {
					"balanced": {
						"css": "&.is-style-balanced { text-wrap: balance; }"
					},
					"eyebrow": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--x-small)",
							"fontWeight": "500",
							"letterSpacing": "0.05em",
							"lineHeight": "var(--wp--custom--line-height--medium)",
							"textTransform": "uppercase"
						}
					},
					"indent": {
						"css": "&.is-style-indent { text-indent: var(--wp--preset--spacing--30); }"
					}
				}
			},
			"core/post-comments-form": {
				"css": "& .form-submit { margin-bottom: 0; }"
			},
			"core/post-excerpt": {
				"variations": {
					"balanced": {
						"css": "&.is-style-balanced { text-wrap: balance; }"
					}
				}
			},
			"core/post-featured-image": {
				"variations": {
					"zoom": {
						"css": "&.is-style-zoom { overflow: hidden; } &.is-style-zoom img { transition: transform var(--powder-motion-slow) var(--powder-motion-ease); } &.is-style-zoom:hover img { transform: scale(var(--powder-motion-scale)); }"
					}
				}
			},
			"core/post-template": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--60)"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--black)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				},
				"variations": {
					"balanced": {
						"css": "&.is-style-balanced { text-wrap: balance; }"
					}
				}
			},
			"core/preformatted": {
				"color": {
					"background": "var(--wp--preset--color--black)",
					"text": "var(--wp--preset--color--white)"
				},
				"css": "{ overflow-x: scroll; tab-size: 4; white-space: pre !important; }",
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--40)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-small)"
				}
			},
			"core/query-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"core/quote": {
				"border": {
					"color": "currentColor",
					"style": "solid",
					"width": "1px"
				},
				"css": "& p { margin: 0; }",
				"elements": {
					"cite": {
						"spacing": {
							"margin": {
								"top": "10px"
							}
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--xx-small)",
							"fontStyle": "normal"
						}
					}
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/search": {
				"css": "& .wp-block-search__input, .wp-element-button { padding: 10px 20px; } & .wp-block-search__input { border-color: var(--wp--preset--color--black); }"
			},
			"core/separator": {
				"border": {
					"color": "currentColor",
					"radius": "0",
					"style": "solid",
					"width": "1px 0 0"
				},
				"css": ":not(.is-style-wide):not(.is-style-dots) { width: 80px; }",
				"spacing": {
					"margin": {
						"right": "0",
						"left": "0"
					}
				},
				"variations": {
					"extended": {
						"css": "&.is-style-extended { width: 180px; }"
					},
					"short": {
						"css": "&.is-style-short { width: 40px; }"
					}
				}
			},
			"core/site-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--black)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "400",
					"lineHeight": "var(--wp--custom--line-height--x-small)"
				}
			},
			"core/social-links": {
				"spacing": {
					"blockGap": "10px"
				},
				"variations": {
					"outline": {
						"css": "& li.wp-block-social-link { background-color: transparent; border: 1px solid currentColor; color: currentColor; }"
					},
					"square": {
						"css": "& .wp-block-social-link { border-radius: 0; }"
					}
				}
			},
			"core/table": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"top": "0 !important"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--black)"
		},
		"css": "::selection { background-color: var(--wp--preset--color--accent); color: var(--wp--preset--color--white); }",
		"elements": {
			"button": {
				"border": {
					"color": "var(--wp--preset--color--accent)",
					"radius": "0",
					"style": "solid",
					"width": "1px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--white)"
				},
				"css": "{ width: auto; }",
				"spacing": {
					"padding": {
						"top": "20px",
						"right": "30px",
						"bottom": "20px",
						"left": "30px"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "400",
					"lineHeight": "var(--wp--custom--line-height--x-small)"
				},
				":hover": {
					"color": {
						"background": "transparent",
						"text": "var(--wp--preset--color--black)"
					}
				},
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--accent)",
						"offset": "1px",
						"style": "solid",
						"width": "2px"
					}
				}
			},
			"caption": {
				"spacing": {
					"margin": {
						"top": "10px",
						"bottom": "0"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-small)"
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "400",
					"lineHeight": "var(--wp--custom--line-height--x-small)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--base)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--black)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				},
				":focus": {
					"outline": {
						"color": "currentColor",
						"offset": "1px",
						"style": "solid",
						"width": "1px"
					}
				},
				"css": "a, a:not(.wp-element-button) { text-decoration-thickness: 1px; text-underline-offset: 2px; }"
			},
			"select": {
				"spacing": {
					"padding": {
						"top": "5px",
						"right": "10px",
						"bottom": "5px",
						"left": "10px"
					}
				}
			},
			"textInput": {
				"border": {
					"color": "currentColor",
					"radius": "0",
					"style": "solid",
					"width": "1px"
				},
				"color": {
					"background": "transparent",
					"text": "inherit"
				},
				"spacing": {
					"padding": {
						"top": "10px",
						"right": "15px",
						"bottom": "10px",
						"left": "15px"
					}
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--30)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--30)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--outfit)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"fontWeight": "300",
			"lineHeight": "var(--wp--custom--line-height--large)"
		}
	},
	"templateParts": [
		{ "area": "header", "name": "header", "title": "Header" },
		{ "area": "footer", "name": "footer", "title": "Footer" },
		{ "area": "navigation-overlay", "name": "navigation-overlay", "title": "Navigation Overlay" }
	],
	"customTemplates": [
